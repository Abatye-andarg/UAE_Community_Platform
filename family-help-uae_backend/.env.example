# ============================================================
# Environment Variables Template — copy to .env and fill in
# ============================================================

# Database
DB_URL=jdbc:mysql://127.0.0.1:host_port/db_shema?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=jwt_secret_key_here
JWT_EXPIRATION_MS=66006060 #jwt expiration ms
